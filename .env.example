# ═══════════════════════════════════════════════════════
# SaveOhioBevs Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════════

# Supabase (required)
SUPABASE_URL=https://psdjlhlqtlkeitmuszmb.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# AWS SES email service (required)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_SES_REGION=us-east-2
FROM_EMAIL=noreply@saveohiobevs.com

# Geocodio (required for address lookup)
GEOCODIO_API_KEY=your-geocodio-api-key-here

# Notification email for business signups (optional, defaults to bobby@50westbrew.com)
NOTIFICATION_EMAIL=bobby@50westbrew.com

# Testing mode (optional - set to true to redirect emails to test recipients)
TESTING_MODE=false
TEST_RECIPIENTS=bobbyslattery@gmail.com,bobby.slattery@fiftywestbrew.com
