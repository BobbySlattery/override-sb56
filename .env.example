# SMTP Configuration for sending emails
# You can use any SMTP provider: Gmail, SendGrid, Mailgun, Amazon SES, etc.

# For Gmail SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password  (NOT your regular password - use an App Password)

# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=  # Optional: override the "from" address (defaults to SMTP_USER)
